# ─────────────────────────────────────────────────────────────────────────────
# Security Scanner — Alert Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# This is a TEMPLATE file. It contains no real credentials.
# To configure alerts: copy .env.example to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_DESKTOP_ALERTS=true
ENABLE_EMAIL_ALERTS=false
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=your_gmail@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ALERT_COOLDOWN_MINUTES=10

# Optional: comma-separated process names to exclude from memory alerts.
# MemCompression, Registry, System, and Idle are excluded by default.
# EXCLUDED_PROCESSES=MemCompression,Registry,System,Idle
